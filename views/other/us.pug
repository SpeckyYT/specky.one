doctype html

include ../includes/embed.pug 
include ../includes/style.pug
include ../includes/popup.pug

head
    title URL shortener
    +embed(
        "URL Shortener",
        "An URL shortener that works sometimes",
        "https://specky.one/us",
        "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRUD-UTMb1WN3V-UfUCueYtvucQUuDXs1jvBA&usqp=CAU",
        "#FF00AA"
    )

body
    h1 URL shortener 
    input(placeholder='URL here')
    button#s Shorten 
    a#url(style='display: none;')

script.
    const inputElement = document.querySelector('input');
    const urlElement = document.querySelector('#url')
    const sendElement = document.querySelector('#s');

    inputElement.addEventListener("change", () => {
        urlElement.style.display = "none";
    })

    sendElement.onclick = async () => {
        const o = await fetch('../us/shorten?url=' + document.querySelector('input').value)
            .then(res => res.json())
            .catch(err => ({ error: `${err}` }));

        if (!o.error) {
            const usURL = `${window.location.origin}${o.url}`;
            urlElement.href = usURL;
            urlElement.innerText = usURL;
            urlElement.style.display = "block";
            try {
                await navigator.clipboard.writeText(usURL)
                popup("URL copied to the clipboard!", "success")
            } catch(err) {
                popup("Failed to copy to the clipboard.", "error")
            }
        } else {
            popup(`Error: ${o.error}`, "error")
        }
    }
